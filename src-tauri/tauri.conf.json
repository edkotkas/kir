{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "kir",
  "version": "0.1.0",
  "identifier": "com.kir.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "kir",
        "width": 360,
        "height": 640,
        "minWidth": 360,
        "minHeight": 640,
        "visible": false,
        "fullscreen": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "publisher": "Eduard Kotkas",
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    }
  },
  "plugins": {
    "updater": {
      "windows": {
        "installMode": "passive"
      },
      "releaseDownloadUrl": "https://github.com/{owner}/{repo}/releases/download/{tag}/{filename}"
    }
  }
}